{
  "description": "msw-maker-base-skill 자동 등록 훅 — CoreVersion 체크 + mlua 자동 진단 + daemon 워밍업",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "MLUA_LSP_CMD=npx MLUA_LSP_ARGS=\"-y @maplestoryworlds/mlua-lsp@1.1.0\" node \"${CLAUDE_PLUGIN_ROOT}/scripts/mlua-lsp/mlua-session-start.cjs\"",
            "timeout": 120
          },
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/inject-agent-md/inject-agents-md.cjs\"",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/core-version-check/core-version-check.cjs\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "MLUA_LSP_CMD=npx MLUA_LSP_ARGS=\"-y @maplestoryworlds/mlua-lsp@1.1.0\" node \"${CLAUDE_PLUGIN_ROOT}/scripts/mlua-lsp/mlua-diagnose-post-tool-use.cjs\"",
            "timeout": 120
          },
          {
            "type": "mcp_tool",
            "server": "msw-maker-mcp",
            "tool": "maker_refresh_workspace"
          }
        ]
      },
      {
        "matcher": "Read|Skill",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/skill-log/skill-log.cjs\"",
            "async": true,
            "timeout": 5
          }
        ]
      }
    ],
    "InstructionsLoaded": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/skill-log/skill-log.cjs\"",
            "async": true,
            "timeout": 5
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "MLUA_LSP_CMD=npx MLUA_LSP_ARGS=\"-y @maplestoryworlds/mlua-lsp@1.1.0\" node \"${CLAUDE_PLUGIN_ROOT}/scripts/mlua-lsp/mlua-session-end.cjs\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
