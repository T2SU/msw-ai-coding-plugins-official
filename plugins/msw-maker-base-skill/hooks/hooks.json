{
  "description": "msw-maker-base-skill auto-registered hooks — CoreVersion check + per-turn skill router reminder + Bash partial-read blocking for skill files + direct read/write blocking for .model/.ui files + automatic mlua diagnostics + daemon warm-up",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/mlua-lsp/mlua-session-start.cjs\"",
            "timeout": 120
          },
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/inject-agent-md/inject-agents-md.cjs\"",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/core-version-check/core-version-check.cjs\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/skill-router-reminder/skill-router-reminder.cjs\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/skill-read-guard/skill-read-guard.cjs\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/structured-file-guard/structured-file-guard.cjs\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Read|Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/structured-file-guard/structured-file-guard.cjs\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/mlua-lsp/mlua-diagnose-post-tool-use.cjs\"",
            "timeout": 120
          },
          {
            "type": "mcp_tool",
            "server": "msw-maker-mcp",
            "tool": "maker_refresh_workspace"
          }
        ]
      },
      {
        "matcher": "Read|Skill",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/skill-log/skill-log.cjs\"",
            "async": true,
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/mcp-log/mcp-log.cjs\"",
            "async": true,
            "timeout": 5
          }
        ]
      }
    ],
    "InstructionsLoaded": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/skill-log/skill-log.cjs\"",
            "async": true,
            "timeout": 5
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/mlua-lsp/mlua-session-end.cjs\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
